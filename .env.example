# ===========================================
# LITESPEED STACK ? CONFIGURACIÓN DESARROLLO
# ===========================================
# ??  NUNCA subas este fichero a git.
#     Ańade .env* a tu .gitignore.
# ===========================================


# ---- PROYECTO ----
# Usado como prefijo en container_name
COMPOSE_PROJECT_NAME=rogpe
PROJECT_NAME=rog.pe
TZ=America/Lima

DOMAIN=rog.local

# ---- RED DOCKER EXTERNA ----
# Crear antes de levantar: docker network create my_network
DOCKER_NETWORK=net_rog


# ---- SCRIPTS INTERNOS ----
APACHE_PUBLIC_ROOT=rog.pe


# =============================================
#  MARIADB
# =============================================
# FIX: todas las variables con prefijo MARIADB_* (consistente con la imagen oficial)
# y con el docker-compose.yml

MARIADB_VERSION=11.3
# Se combina con COMPOSE_PROJECT_NAME
MARIADB_CONTAINER_NAME=mariadb
MYSQL_PORT=3306

MARIADB_DATABASE=rog_web
MARIADB_USER=rog_web
MARIADB_PASSWORD=cesar203
MARIADB_ROOT_PASSWORD=Ccesar203

# Aliases para compatibilidad con phpMyAdmin y scripts legacy
MYSQL_HOST=mariadb
MYSQL_DATABASE=rog_web
MYSQL_USER=rog_web
MYSQL_PASSWORD=cesar203
MYSQL_ROOT_PASSWORD=cesar203
MYSQL_USER_ROOT=root


# =============================================
#  OPENLITESPEED + PHP
# =============================================

WEB_CONTAINER_NAME=rogpe-litespeed
OLS_IMAGE=litespeedtech/openlitespeed:1.7.19

ADMIN_USER=admin
ADMIN_PASS=cesar203

# Puertos
HTTP_PORT=80
ADMIN_PORT=7080
SSH_PORT=2222

# SSH interno al contenedor
SSH_USER=webuser
SSH_PASSWORD=cesar203

# PHP
PHP_VERSION=83
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=120
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_MAX_INPUT_VARS=3000


# =============================================
#  phpMyAdmin
# =============================================

HOST_MACHINE_PMA_PORT=8080
UPLOAD_LIMIT=64M
MEMORY_LIMIT=256M


# =============================================
#  USUARIO Y GRUPO DEL SISTEMA
# =============================================
# Obtener con: id -u  /  id -g
USER_NAME=cesar
UID=1000
GID=1000
NOBODY_USER=65534
NOBODY_GROUP=65534





# =============================================
#  SEGURIDAD Y ENCRIPTACIÓN
# =============================================
# Generar con: openssl rand -hex 32
JWT_SECRET=REEMPLAZAR_openssl_rand_hex_32

# Generar con: openssl rand -hex 16
ENCRYPTION_KEY=REEMPLAZAR_openssl_rand_hex_16


# =============================================
#  RENDIMIENTO
# =============================================

ENABLE_OPCACHE=true
ENABLE_REDIS_CACHE=false
ENABLE_SSL=false


# =============================================
#  MONITOREO Y LOGS
# =============================================

ENABLE_MONITORING=false
LOG_LEVEL=warn
MAX_LOG_SIZE=100M


# =============================================
#  RED
# =============================================

ALLOWED_IPS=0.0.0.0/0
MAX_CONNECTIONS=1000


# =============================================
#  DESARROLLO
# =============================================
# ??  Cambiar a false en producción

DEBUG_MODE=true
SHOW_ERRORS=true


# =============================================
#  BACKUPS
# =============================================

BACKUP_RETENTION_DAYS=7
BACKUP_TIME_HOUR=2
BACKUP_TIME_MINUTE=0


# =============================================
#  CODE-SERVER (VS Code Web)
# =============================================

CODE_SERVER_PORT=8443
CODE_SERVER_PASSWORD=cesar203

# =============================================
#  Tinyfile manager
# =============================================

TINY_FILE_MANAGER_PORT=8091
TINY_FILE_MANAGER_ENABLED=false