# ================================================================
# API REST SYNC - Apache Configuration
# ================================================================
# This file configures Apache for a PHP REST API with security rules
# optimized for API endpoints (not WordPress or general websites)
# ================================================================

# ================================================================
# SECURITY HEADERS
# ================================================================
<IfModule mod_headers.c>
    # API identification
    Header set X-Powered-By "API-REST-SYNC/1.0"

    # CORS - Allow all origins (ajustar en producción)
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"

    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"

    # Remove server information
    Header unset X-Powered-By
    Header unset Server
</IfModule>

ServerSignature Off

# ================================================================
# BASIC SECURITY
# ================================================================

# Protect sensitive files
<FilesMatch "^(\.htaccess|\.env|composer\.json|composer\.lock|\.git)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes

# Limit request body size to 10MB
LimitRequestBody 10485760

# ================================================================
# FIREWALL RULES - Optimized for REST API
# ================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block malicious user agents
    RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
    RewriteCond %{HTTP_USER_AGENT} (bot|crawler|spider|scraper|wget|curl\-test) [NC]
    RewriteCond %{HTTP_USER_AGENT} !^(curl|postman|insomnia|httpie) [NC]
    RewriteRule .* - [F,L]

    # Block SQL injection attempts in query strings
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|update|delete|concat|script|javascript|eval|base64) [NC]
    RewriteRule .* - [F,L]

    # Block XSS attempts
    RewriteCond %{QUERY_STRING} (<script|<iframe|<object|<embed|javascript:) [NC]
    RewriteRule .* - [F,L]

    # Block path traversal attempts
    RewriteCond %{QUERY_STRING} (\.\.\/|\.\.\\|\/etc\/passwd|\/proc\/|\/bin\/) [NC]
    RewriteRule .* - [F,L]

    # Block access to sensitive files
    RewriteRule ^(\.git|\.env|composer\.(json|lock)|package\.json|node_modules) - [F,L]
</IfModule>

# ================================================================
# DIRECTORY PROTECTION
# ================================================================
# Protect internal directories from direct access

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule (^|/)Config(/|$) - [F,L]
    RewriteRule (^|/)Controllers(/|$) - [F,L]
    RewriteRule (^|/)Libs(/|$) - [F,L]
    RewriteRule (^|/)Logs(/|$) - [F,L]
    RewriteRule (^|/)Models(/|$) - [F,L]
    RewriteRule (^|/)Routers(/|$) - [F,L]
    RewriteRule (^|/)vendor(/|$) - [F,L]
    RewriteRule (^|/)Views(/|$) - [F,L]
</IfModule>

# ================================================================
# MAIN ROUTING CONFIGURATION
# ================================================================

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Set rewrite base for API
    RewriteBase /api_rest_sync/

    # Handle OPTIONS requests for CORS preflight
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]

    # Don't rewrite if file or directory exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route all requests to index.php
    RewriteRule ^(.*)$ /api_rest_sync/index.php [QSA,L]
</IfModule>

# ================================================================
# PERFORMANCE OPTIMIZATION
# ================================================================

<IfModule mod_deflate.c>
    # Enable compression for text-based responses
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
</IfModule>

# ================================================================
# ERROR HANDLING
# ================================================================

# Custom error pages can be defined here if needed
# ErrorDocument 404 /api_rest_sync/index.php
# ErrorDocument 500 /api_rest_sync/index.php
